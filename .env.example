# Copier en .env (jamais commité — voir .gitignore).

# --- Backend ---
PORT=3001
# IP Tailscale de ce Mac mini (voir `tailscale ip -4`), ou 127.0.0.1 en local.
# Seuls le loopback (127.0.0.0/8, localhost, ::1) et une adresse Tailscale
# (100.64.0.0/10, fd7a:115c:a1e0::/48) sont acceptés. JAMAIS 0.0.0.0 ni :: (voir CLAUDE.md).
BIND_HOST=100.66.217.18
# Token bearer pour l'API (Authorization: Bearer <token>).
# Au moins 16 caractères ; générer avec `openssl rand -hex 32`.
AUTH_TOKEN=change-me

# --- OpenClaw ---
OPENCLAW_HOME=/Users/xxx/openclaw
GATEWAY_URL=http://127.0.0.1:8080
# Token partagé de la gateway (gateway.auth.token dans ~/.openclaw/openclaw.json).
# Sert à l'auth device-signée du chat (voir src/gateway/), distinct d'AUTH_TOKEN.
GATEWAY_AUTH_TOKEN=change-me

# --- Ollama (fallback qwen3.5:9b) ---
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_FALLBACK_MODEL=qwen3.5:9b

# --- Réseau ---
# Laisser vide pour auto-détecter la passerelle par défaut (route -n get default).
ORANGE_GATEWAY_IP=

# --- Persistance ---
DB_PATH=./data/clawdeck.sqlite
